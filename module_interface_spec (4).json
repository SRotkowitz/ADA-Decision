  "cross_module_dependencies": [
    {
      "field": "is_covered_employer",
      "produced_by": { "module": "ada_coverage_eligibility", "component": "employer_coverage (1.1)" },
      "consumed_by": [
        { "module": "ada_accommodation_analysis", "component": "accommodation_determination (2.4) — short-circuit step 1" },
        { "module": "ada_employer_obligations", "component": "all components — prerequisite for obligations" },
        { "module": "ada_violation_risk", "component": "failure_to_accommodate (4.1) — prima facie element 1" }
      ],
      "notes": "If false, Module 2 short-circuits at step 1 and all downstream obligations are not operative."
    },
    {
      "field": "is_covered_individual",
      "produced_by": { "module": "ada_coverage_eligibility", "component": "individual_status (1.2)" },
      "consumed_by": [
        { "module": "ada_accommodation_analysis", "component": "accommodation_determination (2.4) — short-circuit step 2" },
        { "module": "ada_employer_obligations", "component": "all components — prerequisite" },
        { "module": "ada_violation_risk", "component": "multiple components" }
      ],
      "notes": "If false, Module 2 short-circuits at step 2."
    },
    {
      "field": "has_qualifying_disability",
      "produced_by": { "module": "ada_coverage_eligibility", "component": "disability_determination (1.3)" },
      "consumed_by": [
        { "module": "ada_accommodation_analysis", "component": "accommodation_determination (2.4) — short-circuit step 3" },
        { "module": "ada_violation_risk", "component": "failure_to_accommodate (4.1) — prima facie element 2; disability_discrimination (4.2); harassment (4.3)" }
      ],
      "notes": "Only 'yes' satisfies prima facie element 2 in Module 4. 'indeterminate' treated as element not met for risk counting in Module 4."
    },
    {
      "field": "accommodation_rights_attach",
      "produced_by": { "module": "ada_coverage_eligibility", "component": "disability_determination (1.3)" },
      "consumed_by": [
        { "module": "ada_accommodation_analysis", "component": "accommodation_determination (2.4) — short-circuit step 4" }
      ],
      "notes": "False for regarded_as-only coverage. Module 2 must not proceed to accommodation analysis when false per 42 U.S.C. § 12201(h)."
    },
    {
      "field": "preliminary_qualified_without_accommodation",
      "produced_by": { "module": "ada_coverage_eligibility", "component": "qualified_individual (1.4)" },
      "consumed_by": [
        { "module": "ada_accommodation_analysis", "component": "accommodation_determination (2.4) — R041 short-circuit step 5" },
        { "module": "wrapper", "component": "is_qualified_individual_composite — WR-1 through WR-5" },
        { "module": "ada_violation_risk", "component": "failure_to_accommodate (4.1) — prima facie element 3" }
      ],
      "notes": "This is a distinct field from the final wrapper composite is_qualified_individual. Module 1 outputs two qualified-individual fields: is_qualified_individual (preliminary, used internally in Module 1) and preliminary_qualified_without_accommodation (the explicit field consumed by Module 2 R041 and the wrapper WR rules). The naming makes the preliminary nature of the value unambiguous and prevents a builder from wiring the wrapper composite into Module 2's short-circuit logic, which would create a circular dependency. The wrapper composite is_qualified_individual is not available until after Module 2 completes."
    },
    {
      "field": "accommodation_required",
      "produced_by": { "module": "ada_accommodation_analysis", "component": "accommodation_determination (2.4)" },
      "consumed_by": [
        { "module": "wrapper", "component": "is_qualified_individual_composite — WR-2, WR-3, WR-4" },
        { "module": "ada_employer_obligations", "component": "interactive_process (3.1)" },
        { "module": "ada_violation_risk", "component": "failure_to_accommodate (4.1) — prima facie element 5" }
      ],
      "notes": "This is why the is_qualified_individual composite must be computed after Module 2 — it is a required input for WR-2 and WR-3."
    },
    {
      "field": "denial_basis",
      "produced_by": { "module": "ada_accommodation_analysis", "component": "accommodation_determination (2.4)" },
      "consumed_by": [
        { "module": "wrapper", "component": "is_qualified_individual_composite — WR-3 condition" }
      ],
      "notes": "WR-3 fires only when denial_basis is undue_hardship or direct_threat. Other denial bases do not trigger WR-3."
    },
    {
      "field": "accommodation_request_valid",
      "produced_by": { "module": "ada_accommodation_analysis", "component": "accommodation_request (2.1)" },
      "consumed_by": [
        { "module": "ada_violation_risk", "component": "failure_to_accommodate (4.1) — prima facie element 4" }
      ],
      "notes": null
    },
    {
      "field": "undue_hardship_applies",
      "produced_by": { "module": "ada_accommodation_analysis", "component": "undue_hardship_analysis (2.2)" },
      "consumed_by": [
        { "module": "ada_violation_risk", "component": "failure_to_accommodate (4.1) — documented_legitimate_denial computed field" }
      ],
      "notes": "'yes' contributes to documented_legitimate_denial, which is a complete affirmative defense in Module 4."
    },
    {
      "field": "direct_threat_exists",
      "produced_by": { "module": "ada_accommodation_analysis", "component": "direct_threat_analysis (2.3)" },
      "consumed_by": [
        { "module": "ada_violation_risk", "component": "failure_to_accommodate (4.1) — documented_legitimate_denial computed field" }
      ],
      "notes": "'yes' contributes to documented_legitimate_denial, which is a complete affirmative defense in Module 4."
    },
    {
      "field": "interactive_process_compliant",
      "produced_by": { "module": "ada_employer_obligations", "component": "interactive_process (3.1)" },
      "consumed_by": [
        { "module": "ada_violation_risk", "component": "failure_to_accommodate (4.1) — process compliance factor in risk derivation" }
      ],
      "notes": "Module 4 R070 treats 'indeterminate' as genuinely uncertain — not as a finding against the employer. See design decision 5."
    }
  ],

  "design_decisions": [
    {
      "id": "DD-1",
      "title": "Why is_qualified_individual is a wrapper-level composite",
      "decision": "Module 1 produces a preliminary assessment (1.4b) before accommodation analysis runs. The final determination requires Module 2's output (accommodation_required) to resolve whether the individual is qualified with accommodation. Computing it in Module 1 would require Module 2's output, creating a circular dependency. The wrapper resolves this after Module 2 completes."
    },
    {
      "id": "DD-2",
      "title": "The preliminary_qualified_without_accommodation pattern",
      "decision": "Module 1 outputs two qualified-individual fields: is_qualified_individual (preliminary, used internally) and preliminary_qualified_without_accommodation (the explicit field consumed by Module 2 R041 and the wrapper WR rules). This naming makes the preliminary nature of the value unambiguous and prevents a builder from wiring the wrapper composite into Module 2's short-circuit logic."
    },
    {
      "id": "DD-3",
      "title": "Tiebreak order for overall_risk_level",
      "decision": "When two or more claim types produce the same maximum risk level, the primary claim is determined by: failure_to_accommodate → disability_discrimination → harassment → retaliation. Rationale: FTA is the most directly actionable ADA claim and should surface first for employer remediation purposes."
    },
    {
      "id": "DD-4",
      "title": "Employee non-participation as weighting factor, not defeater",
      "decision": "When an employee refuses or abandons the interactive process with documented basis, the engine shifts the derived FTA risk level one tier downward. It does not floor the risk at minimal. Rationale: courts and EEOC enforcement treat employee non-participation as a partial defense that mitigates but does not eliminate employer liability."
    },
    {
      "id": "DD-5",
      "title": "interactive_process_compliant = indeterminate in Module 4",
      "decision": "Module 4 R070 treats indeterminate as genuinely uncertain — not as a finding against the employer. An indeterminate process compliance finding produces high risk (one tier below the non_compliant → critical outcome), not critical. This reflects that mixed facts on process quality are meaningfully different from documented bad faith."
    }
  ]
}
