  "engine": {
    "name": "ADA Decision Engine",
    "version": "0.1",
    "legal_domain": "Americans with Disabilities Act — Title I (Employment)",
    "governing_law": ["42 U.S.C. §§ 12111–12117", "29 CFR Part 1630"],
    "enforcing_agency": "EEOC",
    "output_repository": "SRotkowitz/ADA-Decision-Engine",
    "determination_model": {
      "rule_based": "Binary boolean. Same input always produces same output.",
      "standards_based": "yes / no / indeterminate with factors_for, factors_against, key_uncertainties arrays. Engine never fakes certainty.",
      "composite": "Combines sub-outputs with explicit documented aggregation logic."
    },
    "field_conventions": {
      "naming": "snake_case",
      "boolean_prefixes": ["is_", "has_", "was_", "can_"],
      "date_format": "YYYY-MM-DD",
      "datetime_format": "ISO8601",
      "categorical_values": "All reference ada_vocabulary.json",
      "risk_levels": ["minimal", "low", "moderate", "high", "critical"],
      "factor_array_order": "alphabetical or by rule_id"
    }
  },
